<%- include("partials/head") %>

<body>

<%- include("partials/header") %>
<%- include("partials/navigation") %>

<main>

<h1>Welcome to CSE Motors!</h1>

<section class="hero">

<div class="hero-text">
<h2>DMC Delorean</h2>

<ul>
<li>3 Cup holders</li>
<li>Superman doors</li>
<li>Fuzzy dice</li>
</ul>

<button>Own Today</button>
</div>

<div class="hero-image">
<img src="/images/vehicles/delorean.jpg" alt="DMC Delorean">
</div>

</section>

<section class="content-grid">

<div class="upgrades">
<h2>Delorean Upgrades</h2>

<div class="upgrade-grid">

<div class="upgrade">
<img src="/images/upgrades/flux-cap.png" alt="Flux Capacitor">
<p>Flux Capacitor</p>
</div>

<div class="upgrade">
<img src="/images/upgrades/flame.jpg" alt="Flame Decals">
<p>Flame Decals</p>
</div>

<div class="upgrade">
<img src="/images/upgrades/bumper-sticker.jpg" alt="Bumper Stickers">
<p>Bumper Stickers</p>
</div>

<div class="upgrade">
<img src="/images/upgrades/hub-cap.jpg" alt="Hub Caps">
<p>Hub Caps</p>
</div>

</div>
</div>

<div class="reviews">
<h2>DMC Delorean Reviews</h2>

<ul>
<li>"So fast it's almost traveling in time"</li>
<li>"Coolest ride on the road"</li>
<li>"I'm feeling lucky"</li>
<li>"The most futuristic ride of our day"</li>
<li>"Why buy another car?"</li>
</ul>

</div>

</section>

</main>

<%- include("partials/footer") %>

</body>